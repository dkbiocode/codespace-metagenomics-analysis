{
  "name": "Metagenomics Analysis (Pre-built Image)",

  // Use pre-built image from GitHub Container Registry
  // This eliminates the 10-15 minute setup.sh installation
  "image": "ghcr.io/meekrob/metagenomics-codespace:latest",

  // Minimal post-create setup (just conda and workspace structure)
  "postCreateCommand": "bash .devcontainer/setup-minimal.sh",

  // Forward RStudio Server port
  "forwardPorts": [8787],

  "portsAttributes": {
    "8787": {
      "label": "RStudio Server",
      "onAutoForward": "notify",
      "protocol": "http"
    }
  },

  // VS Code customizations
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "REditorSupport.r"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "r.rterm.linux": "/usr/local/bin/R",
        "r.rpath.linux": "/usr/local/bin/R"
      }
    }
  },

  // Run as rstudio user
  "remoteUser": "rstudio",

  // Container environment variables
  "containerEnv": {
    "DISABLE_AUTH": "true",
    "PASSWORD": "metagenomics"
  },

  // Add conda feature
  "features": {
    "ghcr.io/devcontainers/features/conda:1": {
      "version": "latest"
    }
  },

  // Lifecycle scripts
  // Note: RStudio Server auto-starts with rocker image
  // To stop it: sudo rstudio-server stop
  // To start manually: sudo rstudio-server start
  "postStartCommand": "echo 'Codespace ready! RStudio Server is available but not started. Run: sudo rstudio-server start'",

  // Override default command to prevent RStudio auto-start
  "overrideCommand": true
}
